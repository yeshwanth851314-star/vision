# VisionOS Environment Variables Example Config Template
# Copy this to .env and fill in real credentials

# 1. AI Gateway & Live Gemini API Configuration
# Paste your Google AI Studio Gemini API Key here
GEMINI_API_KEY=your_gemini_api_key_here

# 2. API Gateway Authentication Configuration
VISIONOS_JWT_SECRET=your_jwt_secret_here
VISIONOS_JWT_ISSUER=expected-issuer
VISIONOS_JWT_AUDIENCE=expected-audience

# 3. Database Configurations
# PostgreSQL Database Connection URL (e.g. for local Docker container or Cloud SQL Proxy)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/visionos?schema=public

# 4. CORS Origins (Comma-separated list of allowed origins)
# For local dev frontend, default: http://localhost:3000,http://localhost:5173
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
