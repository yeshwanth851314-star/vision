{
  "name": "@visionos/api-gateway",
  "version": "1.0.0",
  "private": true,
  "description": "Node.js 22 + Fastify + Socket.io v4 Real-Time Gateway with PostgreSQL/PostGIS ORM for VisionOS",
  "main": "./dist/server.js",
  "scripts": {
    "build": "esbuild src/server.ts --bundle --platform=node --target=node22 --outfile=dist/server.js --external:fastify --external:@fastify/* --external:@prisma/client --external:socket.io --external:zod",
    "dev": "tsc --watch",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "db:migrate": "prisma migrate deploy",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "@fastify/cors": "^11.3.0",
    "@fastify/helmet": "^13.1.0",
    "@fastify/rate-limit": "^11.1.0",
    "@prisma/client": "^5.20.0",
    "@visionos/ai-router": "workspace:*",
    "@visionos/shared": "workspace:*",
    "fastify": "^5.0.0",
    "socket.io": "^4.8.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "esbuild": "^0.28.1",
    "prisma": "^5.20.0",
    "typescript": "^5.6.3"
  }
}
