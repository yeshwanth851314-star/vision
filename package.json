{
  "name": "visionos-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "VisionOS: AI Operating System for Smart Stadiums — Enterprise pnpm / Turborepo Monorepo",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --no-cache --continue",
    "lint": "turbo run lint",
