    "clean": "turbo run clean && rm -rf node_modules apps/*/node_modules packages/*/node_modules dist"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
